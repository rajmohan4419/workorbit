# Copy this file to .env and fill in your Supabase project values
# Get these from: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Grafana Loki Log Capture Configuration
# The root URL of your Grafana Loki instance (e.g. http://localhost:3100 or Grafana Cloud URL)
VITE_LOKI_URL=
# User ID for Loki basic authentication (required for Grafana Cloud, optional for local Loki)
VITE_LOKI_USER=
# API token, password, or bearer token for Loki authentication
VITE_LOKI_TOKEN=
# Optional tenant ID header (X-Scope-OrgID) for multi-tenant Loki setups
VITE_LOKI_TENANT_ID=
# Enable or disable Grafana Loki logging explicitly ("true" or "false")
VITE_LOKI_ENABLED=true
